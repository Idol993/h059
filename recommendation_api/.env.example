APP_NAME=Recommendation API
API_VERSION=v1
DEBUG=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

ITEMS_DB_PATH=data/items.db
BEHAVIORS_DB_PATH=data/behaviors.db

RECOMMENDATION_CACHE_TTL=300
USER_PROFILE_CACHE_TTL=600

HOTNESS_WEIGHT=0.3
COLLABORATIVE_WEIGHT=0.4
CONTENT_WEIGHT=0.3

SVD_N_FACTORS=50
SVD_RANDOM_STATE=42

MIN_USER_BEHAVIORS=5
INCREMENTAL_TRAIN_THRESHOLD=1000
MAX_TRAIN_INTERVAL_SECONDS=3600

TFIDF_MAX_FEATURES=5000
KNN_NEIGHBORS=50

VECTOR_CACHE_SIZE=10000

DEFAULT_AB_GROUP=default

LOG_LEVEL=info
